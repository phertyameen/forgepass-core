{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",
    "outDir": "./dist",
    "types": ["node"],
    "rootDir": "./src",
    "paths": {
      "@common/*": ["./src/common/*"],
      "@modules/*": ["./src/modules/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test"]
}